DENTALSTOCK_SERVER_PORT=8787
DENTALSTOCK_SERVER_HOST=127.0.0.1
DENTALSTOCK_ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
DENTALSTOCK_RATE_LIMIT_WINDOW_MS=60000
DENTALSTOCK_RATE_LIMIT_MAX=120

# Set in production only. When empty, vendor credential write endpoints stay disabled.
DENTALSTOCK_INTERNAL_ADMIN_TOKEN=

# Frontend adapter. Keep local until the backend has real persistence.
VITE_DENTALSTOCK_API_MODE=local
VITE_DENTALSTOCK_API_BASE_URL=http://127.0.0.1:8787
